{
  "name": "backend-assessment",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "typescript-eslint": "^8.21.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm --filter \"./apps/*\" run test",
    "test:cov": "pnpm --filter \"./apps/*\" run test:cov",
    "proto:generate": "pnpm --filter @packages/proto generate",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "migrate:user": "node scripts/migrate-dev.mjs user",
    "migrate:wallet": "node scripts/migrate-dev.mjs wallet",
    "migrate:deploy": "node scripts/migrate-deploy.mjs",
    "prisma:generate": "node scripts/prisma-generate.mjs",
    "dev:wallet": "pnpm --filter @apps/wallet-service start:dev",
    "dev:user": "pnpm --filter @apps/user-service start:dev",
    "smoke": "node scripts/smoke.mjs"
  }
}
